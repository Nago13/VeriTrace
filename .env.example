# ── Core API keys ─────────────────────────────────────────────
BRIGHT_DATA_API_KEY=your_bright_data_api_token_here
AIML_API_KEY=your_aiml_api_key_here
COGNEE_API_KEY=your_cognee_api_key_here
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional. Devnet signer for on-chain commitment. base58 string OR a JSON
# byte array like [12,34,...]. If unset, an ephemeral keypair is generated
# (it will need a devnet airdrop, attempted automatically).
SOLANA_PRIVATE_KEY=

# ── Bright Data zones ─────────────────────────────────────────
# Create these zones in your Bright Data dashboard and put their
# names here. The SERP zone powers search; the Unlocker zone
# powers full-page fetches.
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker

# Optional: proxy host for Web Unlocker (proxy-based fetch).
# Format used by Bright Data super proxy.
BRIGHT_DATA_PROXY_HOST=brd.superproxy.io
BRIGHT_DATA_PROXY_PORT=33335
# Proxy username is built as: brd-customer-<CUSTOMER_ID>-zone-<zone>
BRIGHT_DATA_CUSTOMER_ID=your_customer_id_here
BRIGHT_DATA_PROXY_PASSWORD=your_proxy_password_here

# ── AI/ML API ─────────────────────────────────────────────────
AIML_API_BASE=https://api.aimlapi.com/v1
# Model for claim extraction. Try "claude-sonnet-4-20250514" if gpt-4o is thin.
AIML_MODEL=gpt-4o

# ── Cognee (evidence graph) ───────────────────────────────────
# LLM key Cognee uses to build the knowledge graph. Can reuse your
# AI/ML API key (OpenAI-compatible) or an OpenAI key.
COGNEE_LLM_API_KEY=your_openai_or_aiml_key_here
COGNEE_VECTOR_DB_PROVIDER=lancedb
# Optional: point Cognee's LLM at the AI/ML API (OpenAI-compatible).
COGNEE_LLM_ENDPOINT=https://api.aimlapi.com/v1
COGNEE_LLM_MODEL=gpt-4o
